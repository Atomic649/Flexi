{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "https://api.flexibusinesshub.com/",
        "IMAGE_URL": "https://api.flexibusinesshub.com/uploads/images/",
        "MOCKUP_IMAGE_URL": "https://api.flexibusinesshub.com/uploads/mock/"
       }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "https://api.flexibusinesshub.com/",
        "IMAGE_URL": "https://api.flexibusinesshub.com/uploads/images/",
        "MOCKUP_IMAGE_URL": "https://api.flexibusinesshub.com/uploads/mock/"
       }
    }
  },
  "submit": {
    "production": {}
  }
}

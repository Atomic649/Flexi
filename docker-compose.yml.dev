#version: '3.8'

# Define Network
networks:
  prosgres-docker-prisma:
    name: prosgres-docker-prisma
    driver: bridge

# Define Services
services:
 
  # Optional Bun-based backend (experimental). Keep NodeJS service for fallback.
  bun-backend:
    build:
      context: ./Flexi-Backend
      dockerfile: Dockerfile.bun
    container_name: bunexpress
    environment:
      - PPG_USER_DATABASE_URL1="postgresql://neondb_owner:npg_IgaC5xO8fKls@ep-curly-unit-ahk87d5m-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require&schema=flexidb"
      - PPG_USER_DATABASE_URL2="postgresql://neondb_owner:npg_3QUE7OSwusTI@ep-spring-meadow-a167dlu2-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
      - NODE_ENV=production
    ports:
      - 3010:3000
    restart: always
    networks:
      - prosgres-docker-prisma
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:3000/" ]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

  expo-web:
    build:
      context: ./Flexi-Frontend
      dockerfile: Dockerfile  # The one you created for static Nginx
    container_name: expo-web
    ports:
      - 8080:80
    networks:
      - prosgres-docker-prisma
    restart: always

  # Postgres Database
  postgresdb:
    image: postgres:15.6
    container_name: flexidb
    volumes:
      - ./postgres_data:/var/lib/postgresql/data
    environment:
      POSTGRES_DB: prismatypedb
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: 123456
    ports:
      - 9649:5432
    restart: always
    networks:
      - prosgres-docker-prisma

  # # Second Postgres Database
  postgresdb2:
    image: postgres:15.6
    container_name: flexiadsdb
    volumes:
      - ./postgres_data2:/var/lib/postgresql/data
    environment:
      POSTGRES_DB: prismatypedb2
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: 123456
    ports:
      - 8956:5432
    restart: always
    networks:
      - prosgres-docker-prisma

  # service สำหรับ PostgreSQL
  postgresN8N:
    image: postgres:15.6
    container_name: n8n_postgres
    restart: always
    environment:
      POSTGRES_DB: prismatypedb3
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: 123456
    ports:
      - 9876:5432
    volumes:
      - ./postgres_data3:/var/lib/postgresql/data
    networks:
      - prosgres-docker-prisma


  # Nginx Reverse Proxy
  nginx:
    image: nginx:latest
    container_name: nginx
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro     
      - ./Flexi-Backend/ssl:/etc/ssl
      - ./Flexi-Frontend/dist:/usr/share/nginx/html   
    ports:
      - 80:80
      - 443:443    
    restart: always
    depends_on:
      - bun-backend
      - expo-web
    networks:
      - prosgres-docker-prisma

  # Jenkins CI/CD
